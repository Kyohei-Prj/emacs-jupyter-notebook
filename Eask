;;; Eask-file --- Eask file for Emacs Jupyter Notebook (EJN)  -*- lexical-binding: t; -*-
(package "ejn" "0.1.0" "Emacs Jupyter Notebook")

;; Minimum Emacs version required
(depends-on "emacs" "30.1")

;; Standard dependencies often used for Jupyter/Notebook integrations
(depends-on "dash")
(depends-on "s")
(depends-on "f")
(depends-on "jupyter")
(depends-on "polymode")

;; Development dependencies (not distributed to users)
(depends-on "ert-runner")
(development "buttercup")
(development "undercover")
(depends-on "undercover")

(source "melpa")
(source "gnu")
